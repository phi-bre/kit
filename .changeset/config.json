{
	"$schema": "https://unpkg.com/@changesets/config@2.3.0/schema.json",
	"changelog": [
		"@changesets/changelog-github",
		{ "repo": "sveltejs/kit", "template": "\n- {summary} {ref}" }
	],
	"commit": false,
	"linked": [],
	"access": "public",
	"baseBranch": "main",
	"bumpVersionsWithWorkspaceProtocolOnly": true,
	"ignore": ["!(@sveltejs/*)"]
}
